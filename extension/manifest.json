{
  "manifest_version": 3,
  "name": "XNative Recursive Learning",
  "version": "1.0",
  "description": "Captures posts from X (Twitter) and forwards them to a backend for analysis.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://twitter.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
